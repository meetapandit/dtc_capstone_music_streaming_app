# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

project_id  = "your-gcp-project-id"
region      = "us-central1"
zone        = "us-central1-a"
environment = "dev"

# GKE
gke_cluster_name     = "music-streaming-cluster"
general_node_count   = 2
general_machine_type = "e2-standard-4"  # 4 vCPU, 16 GB — Airflow, Superset, Kafka
data_node_count      = 3
data_machine_type    = "e2-standard-8"  # 8 vCPU, 32 GB — Flink, ClickHouse, Trino

# GCS — bucket names must be globally unique, so prefix with your project-id
iceberg_bucket_name       = "your-gcp-project-id-iceberg-warehouse"
raw_events_bucket_name    = "your-gcp-project-id-raw-events"
dbt_artifacts_bucket_name = "your-gcp-project-id-dbt-artifacts"
